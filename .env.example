# ==========================================
# ORBITA - Environment Variables Example
# Copy this file to `.env` in the backend directory.
# ==========================================

# ── App ───────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=True

# ── Auth ───────────────────────────────────────────────────
# Generate a secure key for production using `openssl rand -hex 32`
SECRET_KEY=orbita_super_secret_jwt_key_2026

# ── Database ──────────────────────────────────────────────
# Replace credentials if you change them in docker-compose
DATABASE_URL=postgresql+asyncpg://orbita_admin:orbita_secret_2026@localhost:5434/orbita_registry
DATABASE_URL_SYNC=postgresql+psycopg2://orbita_admin:orbita_secret_2026@localhost:5434/orbita_registry

# ── Redis ─────────────────────────────────────────────────
# Used for Celery background tasks
REDIS_URL=redis://localhost:6380/0

# ── External APIs (AI Investigation) ──────────────────────
# Required for Langchain ReAct agent generating automated reports
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
