DATABASE_URL=postgresql+asyncpg://orbita_admin:orbita_secret_2026@localhost:5432/orbita_registry
DATABASE_URL_SYNC=postgresql+psycopg2://orbita_admin:orbita_secret_2026@localhost:5432/orbita_registry
